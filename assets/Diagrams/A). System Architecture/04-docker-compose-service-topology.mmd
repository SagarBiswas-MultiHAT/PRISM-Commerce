flowchart LR
  %% Diagram 04: Docker Compose Service Topology (Readable Layout)

  subgraph APPS[Ingress and Application Services]
    WEB[web\nNext.js Container]
    API[api\nNestJS Container]
    WRK[worker\nBullMQ Worker Process]
  end

  subgraph DATA[Stateful Data Services]
    PGB[pgbouncer]
    PGP[(postgres-primary)]
    PGR[(postgres-replica)]
    RED[(redis)]
    MEI[(meilisearch)]
  end

  subgraph AI[AI Service]
    OLL[ollama]
  end

  subgraph OBS[Observability Services]
    OTel[otel-collector]
    PRM[prometheus]
    LOK[loki]
    TMP[tempo]
    GRF[grafana]
  end

  subgraph VOL[Persistent Volumes]
    VPG[(vol-postgres-primary)]
    VPR[(vol-postgres-replica)]
    VRED[(vol-redis)]
    VMEI[(vol-meilisearch)]
    VGRAF[(vol-grafana)]
    VLOK[(vol-loki)]
    VOLL[(vol-ollama)]
    VTMP[(vol-tempo)]
  end

  subgraph CTRL[Compose Controls]
    NET[Network\nprism_internal]
    SEC[Secrets and env\n.env + Docker secrets]
    HC[Healthcheck Policy\nweb/api/pgbouncer/postgres/redis/meili]
    RP[Restart Policy\nunless-stopped]
    BOOT[Startup Order\ndata -> api -> web/worker]
  end

  SentryExt[Sentry\nExternal SaaS Error Tracking]

  WEB -->|HTTPS Internal| API
  API -->|SQL| PGB
  WRK -->|SQL| PGB
  PGB -->|Write| PGP
  PGB -->|Read| PGR
  PGP -->|Streaming Replication| PGR

  API <--> |Cache/Queue/PubSub| RED
  WRK <--> |Jobs| RED
  API <--> |Index/Search| MEI
  API <--> |LLM Runtime| OLL

  WEB --> OTel
  API --> OTel
  WRK --> OTel
  OTel --> PRM
  OTel --> LOK
  OTel --> TMP
  PRM --> GRF
  LOK --> GRF
  TMP --> GRF
  API -->|Errors| SentryExt
  WEB -->|Errors| SentryExt

  PGP --> VPG
  PGR --> VPR
  RED --> VRED
  MEI --> VMEI
  GRF --> VGRAF
  LOK --> VLOK
  OLL --> VOLL
  TMP --> VTMP

  NET -.connects.-> APPS
  NET -.connects.-> DATA
  NET -.connects.-> AI
  SEC -.injected.-> APPS
  SEC -.injected.-> PGB
  HC -.applies.-> APPS
  HC -.applies.-> DATA
  RP -.applies.-> APPS
  BOOT -.orders startup.-> DATA
  BOOT -.then.-> API
  BOOT -.then.-> WEB
  BOOT -.then.-> WRK
