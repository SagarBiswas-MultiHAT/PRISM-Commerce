flowchart TB
  %% Diagram 03: NestJS Modular Monolith - Module Dependency Map (Readable Layout)

  subgraph ACCESS[Access and Governance]
    Auth[AuthModule]
    Compliance[ComplianceModule]
  end

  subgraph CORE[Core Commerce Modules]
    User[UserModule]
    Product[ProductModule]
    Inventory[InventoryModule]
    Order[OrderModule]
    Payment[PaymentModule]
    Escrow[EscrowModule]
    Logistics[LogisticsModule]
  end

  subgraph PLATFORM[Cross-Cutting Platform]
    CQRS[CqrsModule\nCommands + Queries + Sagas]
    EventStore[EventStoreModule\nAppend-Only Domain Events]
    Notify[NotificationModule]
    Audit[AuditModule]
  end

  subgraph INTEL[Intelligence and Insights]
    Analytics[AnalyticsModule]
    AI[AIModule]
  end

  subgraph ADMIN[Control Plane]
    Admin[AdminModule]
  end

  Auth --> User
  User --> Product
  Product --> Inventory
  Product --> Order
  Inventory --> Order
  Order --> Payment
  Payment --> Escrow
  Order --> Logistics

  Compliance --> Payment
  Compliance --> Escrow

  Order --> CQRS
  Payment --> CQRS
  Escrow --> CQRS
  Logistics --> CQRS
  CQRS --> EventStore

  EventStore --> Notify
  EventStore --> Analytics
  EventStore --> AI
  EventStore --> Audit

  Order -.business notifications.-> Notify
  Payment -.payment notifications.-> Notify
  Analytics --> AI

  Auth --> Admin
  Compliance --> Admin
  Analytics --> Admin
  Audit --> Admin

  Stable[Stable Core\nAuth, User, Product, Order, Payment]
  Evolving[Evolving Domain\nAI, Analytics, Agentic Features]

  Stable -.versioned contracts.-> CQRS
  Evolving -.bounded by events.-> EventStore

  classDef core fill:#e7f0ff,stroke:#2a4b8d,stroke-width:1px;
  classDef cross fill:#fff3e2,stroke:#8a4f08,stroke-width:1px;
  classDef gov fill:#eaf9ea,stroke:#1b6b2f,stroke-width:1px;

  class Auth,User,Product,Inventory,Order,Payment,Escrow,Logistics core;
  class CQRS,EventStore,Notify,AI,Analytics cross;
  class Compliance,Audit,Admin gov;
