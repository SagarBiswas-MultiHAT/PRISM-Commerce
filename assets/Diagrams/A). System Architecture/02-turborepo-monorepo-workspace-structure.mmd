flowchart TB
  %% Diagram 02: Turborepo Monorepo Workspace Structure (Readable Layout)

  Root[PRISM-Commerce Monorepo]

  subgraph ROOTCFG[Root Configuration]
    TurboCfg[turbo.json]
    PnpmWs[pnpm-workspace.yaml]
    TsBase[tsconfig.base.json]
    EnvSchema[Environment Schema]
  end

  subgraph WS[Workspace Packages and Apps]
    direction LR

    subgraph APPS[apps]
      Web[web\nNext.js 15 + next-intl]
      Api[api\nNestJS 10 + CQRS]
    end

    subgraph PKG[packages]
      UI[ui\nShared UI + Design Tokens]
      Types[types\nShared DTOs + Domain Types]
      SDK[sdk\nTyped API Client]
      Config[config\nESLint + TypeScript + Env Contracts]
    end

    subgraph INFRA[infra]
      Docker[docker\nCompose + Dockerfiles]
      Mon[monitoring\nPrometheus/Grafana/Loki/Tempo]
      Scripts[scripts\nMigrate/Backup/Deploy]
    end

    subgraph DOCS[docs]
      Diag[diagrams\nMermaid Sources + Index]
    end
  end

  subgraph DEP[Dependency Lanes]
    direction LR
    Web --> UI
    Web --> Types
    Web --> SDK
    Web --> Config
    Api --> Types
    Api --> Config
    Api --> SDKGen
    SDKGen[OpenAPI -> SDK Generation] --> SDK
    SDK --> Types
  end

  subgraph PIPE[CI/CD Pipeline]
    direction LR
    CI[GitHub Actions] --> Lint[lint] --> Typecheck[typecheck] --> Test[test] --> Build[build] --> Deploy[deploy]
  end

  AppTargets[Pipeline Targets\napps/web + apps/api]
  PkgTargets[Pipeline Targets\npackages/ui + packages/sdk + packages/types]
  Cache[Turbo Cache\nLocal + Remote]
  Boundary[Workspace Boundary\nWeb consumes API contracts through packages/sdk]

  Root --> ROOTCFG
  Root --> WS
  ROOTCFG --> PIPE

  Lint -.checks.-> AppTargets
  Typecheck -.checks.-> AppTargets
  Typecheck -.checks.-> PkgTargets
  Test -.runs on.-> AppTargets
  Build -.builds.-> AppTargets
  Build -.builds.-> PkgTargets

  Lint --> Cache
  Typecheck --> Cache
  Test --> Cache
  Build --> Cache

  Docker --> AppTargets
  Mon --> AppTargets
  Scripts --> AppTargets

  Boundary -.enforced by dependency rules.-> Web
  Boundary -.enforced by dependency rules.-> Api
  Boundary -.enforced by dependency rules.-> SDK
