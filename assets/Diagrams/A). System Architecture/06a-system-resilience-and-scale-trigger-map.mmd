flowchart TB
  %% Diagram 06A: System Resilience and Scale Trigger Map

  subgraph TRAFFIC[Traffic and Reliability Controls]
    Edge[Cloudflare Edge\nWAF + DDoS + CDN]
    Gateway[API Gateway\nRate Limit + Auth + Versioning]
    Breaker[Circuit Breakers\nExternal Dependency Protection]
    Retry[Retry Queue\nExponential Backoff]
  end

  subgraph RUNTIME[Runtime Services]
    API[NestJS API]
    Worker[BullMQ Workers]
    RT[Realtime Gateway]
    Cache[(Redis)]
    Search[(Meilisearch)]
    DB[(PostgreSQL + Read Replica\nvia PgBouncer)]
  end

  subgraph OBS[SLO and Incident Signals]
    SLO[SLO Monitors\nLatency, Error Rate, Saturation]
    Alert[Alerting + On-Call]
    Dash[Grafana + Tempo + Loki + Sentry]
  end

  subgraph SCALE[Scale Triggers]
    T1[p95 API above target\nfor sustained window]
    T2[Queue depth grows\nwithout recovery]
    T3[Read replica lag exceeds\nquery tolerance]
    T4[WSS connection churn spikes]
  end

  subgraph ACTION[Response Paths — Escalation Levels]
    L1[Level 1: Tune\nCache TTL + Query Plans + Index]
    L2[Level 2: Scale Replicas\nDocker Compose Replicas\napi=2, worker=3]
    L3[Level 3: Split\nExtract Hot Modules\nto Independent Services]
    L4[Level 4: Migrate\nKubernetes when\nCompose Limits Reached]
  end

  Edge --> Gateway --> API
  API --> Cache
  API --> Search
  API --> DB
  Worker --> Cache
  Worker --> DB
  RT --> API

  API --> Breaker
  Breaker --> Retry
  Retry --> Worker

  API --> SLO
  Worker --> SLO
  RT --> SLO
  SLO --> Dash
  SLO --> Alert

  SLO --> T1
  SLO --> T2
  SLO --> T3
  SLO --> T4

  T1 -->|First response| L1
  T2 -->|First response| L2
  T3 -->|First response| L1
  T4 -->|First response| L2

  L1 -.if insufficient.-> L2
  L2 -.if insufficient.-> L3
  L3 -.if Compose limits reached.-> L4
