flowchart TB
  %% Diagram 01: PRISM V4 - High-Level System Architecture Overview (Readable Layout)

  subgraph EXP[Experience Layer]
    Clients[Buyer/Vendor/Admin Web + Mobile Apps]
  end

  subgraph EDGE[Edge and Access Layer]
    CF[Cloudflare\nDNS + CDN + WAF + DDoS]
    APIGW[API Gateway\nRouting + Auth + Rate Limits]
    RTGW[Realtime Gateway\nWSS Primary + SSE Fallback]
  end

  subgraph APP[Application Layer]
    API[NestJS Modular Monolith\nCQRS Commands + Queries]
    Worker[BullMQ Workers\nAsync Jobs + Projections]
  end

  subgraph DATA[Data and Search Layer]
    PGB[PgBouncer\nConnection Pool]
    PGW[(PostgreSQL Primary\nWrite Model + Event Store)]
    PGR[(PostgreSQL Read Replica\nQuery Offload)]
    Redis[(Redis 7\nCache + Queue + Pub/Sub)]
    Mei[(Meilisearch\nLexical Search)]
    Vec[(pgvector\nSemantic Retrieval)]
    ObjStore[(Object Storage\nCloudflare R2 / MinIO)]
  end

  subgraph AI[Intelligence Layer]
    ONNX[ONNX Runtime\nGBR Inference]
    SAH[Sahayak Runtime\nOllama Primary]
    GPT[OpenAI GPT-4o\nTiered Fallback]
  end

  subgraph EXT[External Integrations]
    Pay[Payments\nbKash, Nagad, SSLCommerz, Bangla QR, Rocket]
    WA[WhatsApp Cloud API]
    L3[3PL APIs\nPathao, RedX, Paperfly, Steadfast, eCourier]
    Weather[OpenWeatherMap]
    Live[LiveKit SFU]
    Social[Facebook, TikTok, YouTube]
  end

  subgraph OBS[Observability]
    OTel[OTel Collector]
    Prom[Prometheus]
    Loki[Loki]
    Tempo[Tempo]
    Graf[Grafana]
    Sentry[Sentry]
  end

  KPI[Targets\np95 API < 200ms\n10K+ Concurrent Users]
  SEC[Security Baseline\nJWT + MFA + RLS + Idempotency]

  Clients -->|HTTPS| CF
  CF -->|HTTPS| APIGW
  APIGW -->|REST| API
  APIGW -->|WSS/SSE Upgrade| RTGW
  RTGW -->|Realtime Streams| Clients

  API -->|SQL| PGB
  Worker -->|SQL| PGB
  PGB -->|Writes| PGW
  PGB -->|Reads| PGR
  PGW -->|Streaming Replication| PGR

  API <--> |Cache + Queue + Pub/Sub| Redis
  Worker <--> |Jobs + Pub/Sub| Redis
  API <--> |Index/Search| Mei
  API <--> |Vector Search| Vec
  Worker -->|Projection Refresh| Mei
  Worker -->|Projection Refresh| PGR

  API -->|Upload Media/Docs| ObjStore
  Worker -->|Async Processing| ObjStore
  ObjStore -->|CDN Delivery| CF

  API <--> |In-Process Inference| ONNX
  API <--> |Tool Calling| SAH
  SAH -.Fallback.-> GPT

  API -->|REST + Webhooks| Pay
  API -->|Template Messaging| WA
  API -->|Shipment Create/Track| L3
  API -->|Weather Signals| Weather
  RTGW -->|Live Events| Live
  API -->|Catalog/Order Sync| Social

  API --> OTel
  Worker --> OTel
  RTGW --> OTel
  OTel --> Prom
  OTel --> Loki
  OTel --> Tempo
  Prom --> Graf
  Loki --> Graf
  Tempo --> Graf
  API --> Sentry

  KPI -.applies to.-> APIGW
  KPI -.applies to.-> API
  SEC -.applies to.-> APIGW
  SEC -.applies to.-> PGW
