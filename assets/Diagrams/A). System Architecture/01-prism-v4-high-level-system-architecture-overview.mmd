flowchart TB
  %% Diagram 01: PRISM V4 - High-Level System Architecture Overview (Production-Grade)

  subgraph EXP[Experience Layer]
    BuyerWeb[Buyer Web App\nNext.js 15]
    VendorWeb[Vendor Web App\nNext.js 15]
    AdminWeb[Admin Console\nNext.js 15]
    Mobile[React Native App\nExpo]
  end

  subgraph EDGE[Edge and Access Layer]
    CF[Cloudflare\nDNS + CDN + WAF + DDoS]
    APIGW[API Gateway\nRouting + Auth + Rate Limits]
    RTGW[Realtime Gateway\nWSS Primary + SSE Fallback]
  end

  subgraph APP[Application Layer]
    Nest[NestJS Modular Monolith\nCQRS Commands + Queries]
    Worker[BullMQ Workers\nAsync Jobs + Projections]
  end

  subgraph DATA[Data and Search Layer]
    PGB[PgBouncer\nConnection Pool]
    PGW[(PostgreSQL Primary\nWrite Model + Event Store Table)]
    PGR[(PostgreSQL Read Replica\nQuery Offload)]
    Redis[(Redis 7\nCache + Queue + Pub/Sub)]
    Mei[(Meilisearch\nLexical Search)]
    Vec[(pgvector\nSemantic Retrieval)]
  end

  subgraph AI[Intelligence Layer]
    ONNX[ONNX Runtime\nGBR Inference]
    SAH[Sahayak Runtime\nOllama Primary]
    GPT[OpenAI GPT-4o\nTiered Fallback]
  end

  subgraph EXT[External Integrations]
    Pay[Payments\nbKash, Nagad, SSLCommerz, Bangla QR, Rocket]
    WA[WhatsApp Cloud API]
    L3[3PL APIs\nPathao, RedX, Paperfly, Steadfast, eCourier]
    Weather[OpenWeatherMap]
    Live[LiveKit SFU]
    Social[Facebook, TikTok, YouTube]
  end

  subgraph OBS[Observability]
    Prom[Prometheus]
    Graf[Grafana]
    Loki[Loki]
    Tempo[Tempo\nOpenTelemetry Traces]
    Sentry[Sentry]
  end

  KPI[Targets\np95 API < 200ms\n10K+ Concurrent Users]
  SEC[Security Baseline\nJWT + MFA + RLS + Idempotency]

  BuyerWeb -->|HTTPS| CF
  VendorWeb -->|HTTPS| CF
  AdminWeb -->|HTTPS| CF
  Mobile -->|HTTPS| CF

  CF -->|HTTPS| APIGW
  APIGW -->|HTTPS Internal| Nest
  APIGW -->|WSS/SSE Upgrade| RTGW
  RTGW -->|Realtime Streams| BuyerWeb
  RTGW -->|Realtime Streams| VendorWeb
  RTGW -->|Realtime Streams| AdminWeb
  RTGW -->|Realtime Streams| Mobile

  Nest -->|SQL via Prisma| PGB
  Worker -->|SQL for Jobs/Projections| PGB
  PGB -->|Writes| PGW
  PGB -->|Reads| PGR
  PGW -->|Streaming Replication| PGR

  Nest <--> |Cache + Queue + Pub/Sub| Redis
  Worker <--> |Jobs + Pub/Sub| Redis
  Nest <--> |Index/Search| Mei
  Nest <--> |Vector Search| Vec
  Worker -->|Projection Refresh| Mei
  Worker -->|Projection Refresh| PGR

  Nest <--> |In-Process Calls| ONNX
  Nest <--> |Tool Calling| SAH
  SAH -.Fallback.-> GPT

  Nest -->|REST + Webhooks| Pay
  Nest -->|Template Messaging| WA
  Nest -->|Shipment Create/Track| L3
  Nest -->|Weather Signals| Weather
  RTGW -->|Live Events| Live
  Nest -->|Catalog/Order Sync| Social

  Prom --> Graf
  Loki --> Graf
  Tempo --> Graf
  Nest --> Prom
  Nest --> Loki
  Nest --> Tempo
  Nest --> Sentry
  Worker --> Prom
  RTGW --> Prom

  KPI -.applies to.-> APIGW
  KPI -.applies to.-> Nest
  SEC -.applies to.-> APIGW
  SEC -.applies to.-> PGW
