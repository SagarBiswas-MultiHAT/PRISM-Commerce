flowchart TB
  %% Diagram 06B: System Data Flow - Key Journeys (Readable Layout)
  %% Source: V4 Section 8.3 Journey A and Journey B

  subgraph JA[Journey A - Buyer Places Order]
    direction TB

    JA_Start([Buyer starts checkout])
    JA_Edge[Cloudflare + API Gateway\nAuth + Validation + Rate Limit]
    JA_Cmd[PlaceOrderCommand]
    JA_Inv[Validate and reserve inventory]
    JA_PayFlow[Process payment and verify webhook]
    JA_Escrow[Hold funds in escrow]
    JA_Confirm[Confirm order and decrement inventory]
    JA_Logistics[Assign 3PL]
    JA_Notify[Notify buyer/vendor\nWhatsApp + WebSocket]
    JA_End([Delivered -> Escrow release -> Vendor payout])

    JA_PaymentGateway[Payment gateways\nbKash/Nagad/SSLCommerz/Bangla QR]
    JA_3PL[3PL partners\nPathao/RedX/Paperfly]
    JA_DB[(PostgreSQL primary + event store)]
    JA_Redis[(Redis cache/pubsub)]

    JA_Start --> JA_Edge --> JA_Cmd --> JA_Inv --> JA_PayFlow --> JA_Escrow --> JA_Confirm --> JA_Logistics --> JA_Notify --> JA_End

    JA_PayFlow --> JA_PaymentGateway
    JA_PaymentGateway -->|Verified callback| JA_PayFlow
    JA_Logistics --> JA_3PL
    JA_Confirm --> JA_DB
    JA_Confirm --> JA_Redis

    JA_Inv -->|Inventory invalid| JA_FailStock([Reject order and notify buyer])
    JA_PayFlow -->|Payment failed| JA_FailPay([Compensate: release inventory])
    JA_Logistics -->|Assignment failed| JA_FailLog([Compensate: refund and release inventory])
  end

  subgraph JB[Journey B - Vendor Uses Agentic Sahayak]
    direction TB

    JB_Start([Vendor asks Sahayak for action guidance])
    JB_Edge[API Gateway\nAuth + Tier Check]
    JB_API[POST /api/ai/sahayak/chat]
    JB_Parse[Parse intent with LLM]
    JB_RAG[Retrieve vendor context\nRAG with pgvector]
    JB_Velocity[Tool call: GET /api/ai/velocity]
    JB_Coupon[Tool call: POST /api/ai/coupon-optimize]
    JB_Create[Optional mutation: POST /api/coupons/bulk-create]
    JB_Confirm[Human confirmation required]
    JB_Response[Return final response to vendor]

    JB_LLM[Ollama primary]
    JB_GPT[OpenAI fallback]
    JB_DB[(PostgreSQL\nconversations + audit logs)]
    JB_Vec[(pgvector embeddings)]

    JB_Start --> JB_Edge --> JB_API --> JB_Parse --> JB_RAG --> JB_Velocity --> JB_Coupon --> JB_Confirm --> JB_Create --> JB_Response --> JB_DB
    JB_Parse --> JB_LLM
    JB_LLM -.fallback.-> JB_GPT
    JB_RAG --> JB_Vec

    JB_LLM -->|Runtime failure| JB_FailLLM([Advisory fallback, no silent mutations])
    JB_Velocity -->|Tool error| JB_FailTool([Return partial result and log incident])
    JB_Confirm -->|Vendor rejects| JB_Cancel([Cancel mutation, keep advisory output only])
  end
