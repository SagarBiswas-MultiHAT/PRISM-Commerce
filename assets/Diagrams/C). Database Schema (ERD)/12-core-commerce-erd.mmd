erDiagram
  %% Diagram 12: Core Commerce ERD

  USERS ||--o| VENDORS : owns_vendor_profile
  USERS ||--o{ ORDERS : places
  VENDORS ||--o{ ORDERS : fulfills
  VENDORS ||--o{ PRODUCTS : owns
  CATEGORIES ||--o{ CATEGORIES : parent_of
  CATEGORIES ||--o{ PRODUCTS : classifies
  PRODUCTS ||--o{ PRODUCT_VARIANTS : has
  ORDERS ||--|{ ORDER_ITEMS : contains
  PRODUCTS ||--o{ ORDER_ITEMS : ordered_as
  PRODUCT_VARIANTS ||--o{ ORDER_ITEMS : selected_variant
  VENDORS ||--o{ COUPONS : issues
  USERS ||--o{ REVIEWS : writes
  PRODUCTS ||--o{ REVIEWS : receives
  ORDERS ||--o{ REVIEWS : verified_purchase
  USERS ||--o{ WISHLISTS : saves
  PRODUCTS ||--o{ WISHLISTS : saved_item

  USERS {
    uuid id PK
    string role
    string email
    string phone
    string whatsapp_number
    string preferred_locale
    boolean is_verified
    boolean mfa_enabled
  }

  VENDORS {
    uuid id PK
    uuid user_id FK
    string shop_name
    string logo
    string description
    string location
    string subscription_tier
    string verification_level
    boolean is_approved
  }

  PRODUCTS {
    uuid id PK
    uuid vendor_id FK
    uuid category_id FK
    string name
    string description
    string slug
    decimal price
    decimal compare_at_price
    jsonb images
    string video_url
    boolean is_active
  }

  PRODUCT_VARIANTS {
    uuid id PK
    uuid product_id FK
    string sku
    string size
    string color
    decimal price_override
    int inventory_count
    string barcode
  }

  CATEGORIES {
    uuid id PK
    uuid parent_id FK
    string name_en
    string name_bn
    string slug
  }

  ORDERS {
    uuid id PK
    uuid buyer_id FK
    uuid vendor_id FK
    string status
    decimal total
    decimal discount
    string payment_method
    string payment_status
    string escrow_status
    string delivery_partner
    string tracking_id
  }

  ORDER_ITEMS {
    uuid id PK
    uuid order_id FK
    uuid product_id FK
    uuid variant_id FK
    int quantity
    decimal unit_price
    decimal subtotal
  }

  COUPONS {
    uuid id PK
    uuid vendor_id FK
    string code
    string discount_type
    decimal discount_value
    decimal min_order
    int max_uses
    datetime valid_from
    datetime valid_to
    boolean is_ai_generated
  }

  REVIEWS {
    uuid id PK
    uuid buyer_id FK
    uuid product_id FK
    uuid order_id FK
    int rating
    string text
    jsonb photo_urls
    string video_url
    boolean is_verified_purchase
    string vendor_response
  }

  WISHLISTS {
    uuid id PK
    uuid buyer_id FK
    uuid product_id FK
  }
